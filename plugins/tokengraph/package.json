{
  "name": "tokengraph",
  "version": "0.20.0",
  "description": "Local-first coding-agent MCP plugin for compact project context routing.",
  "type": "module",
  "private": true,
  "license": "SEE LICENSE IN LICENSE",
  "engines": {
    "node": ">=22"
  },
  "packageManager": "pnpm@10.14.0",
  "bin": {
    "tokengraph-mcp": "./dist/index.js",
    "tokengraph": "./dist/cli.js"
  },
  "scripts": {
    "build": "node scripts/build.mjs",
    "pretest": "pnpm build",
    "test": "vitest run",
    "typecheck": "tsc -p tsconfig.json --noEmit && tsc -p tsconfig.test.json --noEmit",
    "smoke": "node scripts/smoke.mjs",
    "benchmark": "node scripts/benchmark.mjs",
    "package:plugin": "node scripts/package-plugin.mjs",
    "validate:plugin": "node scripts/validate-plugin.mjs"
  },
  "dependencies": {
    "@modelcontextprotocol/server": "2.0.0-beta.2",
    "ignore": "^5.3.2",
    "zod": "^4.0.0"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "esbuild": "^0.28.1",
    "fflate": "0.8.3",
    "typescript": "5.9.3",
    "vite": "6.4.3",
    "vitest": "^3.2.6"
  }
}
